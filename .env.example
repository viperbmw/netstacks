# NetStacks Configuration
# Copy this file to .env and customize for your environment

# Netstacker API Key (shared between backend and frontend)
NETSTACKER_API_KEY=2a84465a-cf38-46b2-9d86-b84Q7d57f288

# NetStacks Web UI Port (default: 8089)
# NETSTACKS_PORT=8089

# Netstacker API Port (default: 9000)
# NETSTACKER_PORT=9000

# Database Configuration
# DB_FILE=/data/netstacks.db
